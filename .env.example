# =============================================================================
# Run Insights ledger
# =============================================================================
# Cross-run telemetry capturing how each run produced its output, which
# errors fired, which direction-debate choices were rejected, and (Quant
# mode only) the runtime parameters that produced the result.  The current
# release writes the ledger; a future retrieval layer will read it to
# inject avoidance hints and reusable-skill hints into Stage 0 / Stage 2.
#
# Storage layout under .crucible_insights/ contains four JSONL streams
# (output, error, debate, params) plus a blobs/<sha256>.json directory
# holding payloads above the inline limit; the directory shape mirrors the
# future Cloudflare R2 object hierarchy so cloud upload is structural.
#
# Master switch — setting this to 0 makes the recorder a complete no-op
# (zero I/O, zero sinks).  CI and benchmark runs can disable it freely.
CRUCIBLE_RUN_INSIGHTS_ENABLED=1

# Per-kind switches that operate independently of the master switch above.
CRUCIBLE_RUN_INSIGHTS_RECORD_OUTPUT=1
CRUCIBLE_RUN_INSIGHTS_RECORD_ERRORS=1
CRUCIBLE_RUN_INSIGHTS_RECORD_DEBATE=1

# Runtime-parameters recording — 'auto' (default) records only on Quant
# runs.  Accepts: auto | 1 | 0 | true | false | yes | no | on | off.
# Typos such as 'atuo' return 'auto' (no silent truthy coercion happens).
CRUCIBLE_RUN_INSIGHTS_RECORD_PARAMS=auto

# Redaction is on by default because runtime_params payloads can embed
# operator config dictionaries containing webhook URLs and API tokens.
CRUCIBLE_RUN_INSIGHTS_REDACT=1

# Backend selector — 'local' (default) writes only the on-disk JSONL ledger;
# 'dual' adds asynchronous cloud sync; 'cloudflare' also reads cloud-first.
CRUCIBLE_RUN_INSIGHTS_BACKEND=local

# Storage tuning knobs (operators rarely change these; defaults are sane).
# Ledger root directory — relative paths anchor to the repo root, not CWD.
# CRUCIBLE_RUN_INSIGHTS_DIR=.crucible_insights
# Inline payload limit — payloads larger than this are sidecar'd into
# .crucible_insights/blobs/<sha256>.json (future R2 object equivalent).
# CRUCIBLE_RUN_INSIGHTS_INLINE_MAX_BYTES=4096
# Per-stream FIFO cap — each of the 4 streams trims to this size; the cap
# acts globally as 4 × this value on disk.  Minimum permitted value: 10.
# CRUCIBLE_RUN_INSIGHTS_MAX_ENTRIES_PER_STREAM=2000

# Cloudflare Workers + D1 + R2 cloud backend (v1.2.0).  These keys are used
# when BACKEND=dual (local durable plus asynchronous cloud sync, recommended)
# or BACKEND=cloudflare (same write and sync path as dual, with cloud-primary
# reads).  Both URL and TOKEN must be set or dual/cloudflare degrade safely to
# a local-only ledger.  See crucible/features/run_insights/backends.py for the
# D1 / R2 / Workers contract and cloudflare/insights-worker/ for the deployable
# Worker together with its full deploy and smoke-test steps.
# Worker endpoint URL for dual or cloudflare backends, for example https://crucible-insights.your-subdomain.workers.dev
CRUCIBLE_RUN_INSIGHTS_API_URL=
# Bearer token sent to the Worker; must match the wrangler secret value exactly.
CRUCIBLE_RUN_INSIGHTS_API_TOKEN=
# Per-request HTTP timeout in seconds for the cloud-sync POST calls (range 1-300).
CRUCIBLE_RUN_INSIGHTS_API_TIMEOUT_SECONDS=10
# Retry attempts per batch before deferring to the next background flush (range 0-10).
CRUCIBLE_RUN_INSIGHTS_API_MAX_RETRIES=3
# Background flush interval in seconds controlling how often events are batched (1-3600).
CRUCIBLE_RUN_INSIGHTS_API_BATCH_FLUSH_SECONDS=30
# Maximum events per batch POST; keep at or below your Workers subrequest limit (1-500).
CRUCIBLE_RUN_INSIGHTS_API_BATCH_SIZE=100

# Reserved keys for the planned retrieval + LLM skill distillation layer
# that consumes this ledger.  The current release ignores all of them.
# CRUCIBLE_RUN_INSIGHTS_RETRIEVAL_ENABLED=1
# CRUCIBLE_RUN_INSIGHTS_INJECT_STAGE0=1
# CRUCIBLE_RUN_INSIGHTS_INJECT_STAGE2=1
# CRUCIBLE_RUN_INSIGHTS_AVOIDANCE_TOPK=3
# CRUCIBLE_RUN_INSIGHTS_SKILL_TOPK=2
# CRUCIBLE_RUN_INSIGHTS_SIMILARITY_THRESHOLD=0.34
# CRUCIBLE_RUN_INSIGHTS_CONFIDENCE_HALFLIFE_DAYS=30
# CRUCIBLE_RUN_INSIGHTS_BAN_THRESHOLD=0.18
# CRUCIBLE_RUN_INSIGHTS_MIN_ATTEMPTS_BEFORE_BAN=2
# CRUCIBLE_RUN_INSIGHTS_INJECT_TOKEN_BUDGET=5000
# CRUCIBLE_RUN_INSIGHTS_RETRIEVAL_SCOPE=auto
# CRUCIBLE_RUN_INSIGHTS_DISTILLATION_ENABLED=1
# CRUCIBLE_RUN_INSIGHTS_DISTILLATION_BUDGET_USD=2.0

# =============================================================================
# Direction Debate Audit Mode (v1.1.8)
# =============================================================================
# Audit-mode capture of the Stage 0 direction debate.  When enabled, each of
# the five specialists (Explorer, Comparator, Skeptic, Evidence Auditor,
# Judge) emits a structured AUDIT_FINDING block containing assumptions,
# evidence, concerns, and explicit disagreements with prior agents.  The
# Judge additionally emits a GATE_VERDICT block in the expanded decision
# space (PROCEED / BRANCH / KILL / NEEDS_MORE_DATA) instead of the legacy
# binary force-none signal.  Two ledger events (debate_finding and
# debate_verdict) land in the existing debate.jsonl stream so v1.2.0
# retrieval can index past disagreements without backfill.
#
# Mira Chen's design observation: the gate's most-valuable output is the
# disagreement log, not the PROCEED/KILL conclusion.  Same-model-family
# crews share blind spots; unanimous high-confidence verdicts are exactly
# the cases where a reviewer should be most suspicious.  v1.1.8 captures
# that suspicion structurally.

# Master switch.  0 = legacy debate flow unchanged.  1 = audit ledger events
# emitted in addition to the legacy DirectionDecision; downstream gate flow
# is NOT changed (v1.1.8 is observation-only by design).
CRUCIBLE_DEBATE_AUDIT_MODE=0

# Enforce that every specialist outputs the structured AUDIT_FINDING block.
# When 1, the orchestrator retries parse-failed findings.  When 0, missing
# findings are silently skipped (audit trail will be sparse).
CRUCIBLE_DEBATE_REQUIRE_STRUCTURED_FINDINGS=1

# Isolation mode for prior-agent context.  ``sequential`` (default) shares
# full prior task output as in v1.1.7.  ``hybrid`` instructs each agent to
# treat prior agents' free-form reasoning as untrusted and rely on the
# structured AUDIT_FINDING blocks instead — reduces sequential anchoring.
CRUCIBLE_DEBATE_ISOLATION_MODE=sequential

# Enable the External Critic — a sixth agent that re-judges the Judge's
# verdict using ONLY the raw research evidence + Judge's decision token.
# Critic does NOT see prior agents' chain-of-thought; v1.1.8 uses the same
# model family as the Judge (v1.3.0 will support cross-family critics).
CRUCIBLE_DEBATE_EXTERNAL_CRITIC=0

# When 1, an External Critic KILL verdict overrides Judge PROCEED.  Default
# 0 — Critic dissent is recorded in the audit trail but Judge verdict
# stands.  Set to 1 in production after the Critic has been calibrated.
CRUCIBLE_DEBATE_CRITIC_OVERRIDE_PROCEED=0

# Concern-diversity threshold for the consensus-risk computation.  Pairwise
# Jaccard distance below this value triggers low_diversity_high_confidence
# flag.  Range [0.0, 1.0]; default 0.3.  Lower = stricter (more sensitive).
CRUCIBLE_DEBATE_CONSENSUS_RISK_THRESHOLD=0.3

# Max retry attempts for the External Critic's LLM call.  Range 1-5;
# default 2.  Hitting the limit returns a NEEDS_MORE_DATA fallback so a
# flaky LLM does not silently KILL viable directions.
CRUCIBLE_DEBATE_CRITIC_MAX_ATTEMPTS=2

# Per-stream ledger toggles for the two new v1.1.8 events.  Both live in
# the existing debate.jsonl stream, so they also respect the existing
# CRUCIBLE_RUN_INSIGHTS_RECORD_DEBATE master toggle above.  ``auto`` on
# RECORD_DEBATE_FINDING follows CRUCIBLE_DEBATE_AUDIT_MODE — findings are
# only meaningful in audit mode so the default is to record only then.
CRUCIBLE_RUN_INSIGHTS_RECORD_DEBATE_FINDING=auto
CRUCIBLE_RUN_INSIGHTS_RECORD_GATE_VERDICT=1

# =============================================================================
# Librarian Provider Authentication (v1.1.10)
# =============================================================================
# Optional API tokens for librarian search providers that have an auth tier.
# Both keys are OPTIONAL — leaving them at the placeholder values keeps the
# provider on its anonymous quota.  Configuring real values lifts the quota
# (and, for context7, is the only way to recover from a quota-exhausted IP).

# Context7 API key — register at https://context7.com/dashboard (free tier).
# Without a key, context7 search runs on the per-IP anonymous monthly quota;
# once that is exhausted every request returns HTTP 429 with a multi-day
# ``Retry-After`` and the librarian loses the provider for the rest of the
# session.  With a key, requests are charged to the dashboard tier instead.
CONTEXT7_API_KEY=replace_with_context7_api_key

# GitHub Personal Access Token (classic) used by the librarian's
# ``search/code`` + ``search/repositories`` calls AND by the
# ``--github-repo`` repo analyzer.  Generate at:
#   GitHub → Settings → Developer settings → Personal access tokens
#                    → Tokens (classic) → Generate new token (classic)
# Minimum scope: ``public_repo`` (read-only access to public repos).
# Without a token: ``search/code`` returns 401 (skipped entirely);
# ``search/repositories`` and the repo analyzer fall back to anonymous,
# which is rate-limited to 10 req/hr and 60 req/hr respectively — both
# easily exhausted in a single run.
# With a token: 30 req/min for search/code, 5000 req/hr for everything else.
# ``GH_TOKEN`` and ``GITHUB_API_TOKEN`` are accepted as fallback names in
# that order, matching the convention used by the GitHub CLI / gh.
GITHUB_TOKEN=replace_with_github_personal_access_token

# Tavily Search API key (v1.1.13) — register at https://app.tavily.com for a
# free tier (1,000 credits per month).  Tavily is an OPTIONAL, opt-in general
# web-search provider that sits between DuckDuckGo and SearXNG in the general
# fallback chain.  It activates ONLY when BOTH this key holds a real value AND
# ``tavily`` is present in LIBRARIAN_EXTRA_PROVIDERS (see below); otherwise the
# provider no-ops and default behaviour is unchanged bit-for-bit.  Leaving this
# at the placeholder value is equivalent to omitting the key — the provider
# filters the same sentinels as the others (replace_*, your_*, xxxx*,
# placeholder*, changeme*).  NOTE: enabling Tavily sends your search queries to
# a third-party commercial API, so review their data policy before using it on
# confidential research topics.
TAVILY_API_KEY=replace_with_tavily_api_key

# =============================================================================
# Web Research Hardening — Search Cache (v1.1.8 extended)
# =============================================================================
# Disk-persistent cache for search-provider responses (DuckDuckGo, context7,
# GitHub, arXiv, paperswithcode, OpenAlex, Crossref, Wikipedia, SearXNG).
# Eliminates the rate-limit burn caused by repeated runs on the same topic
# because refinement iterations hit cache instead of re-fetching from the
# provider.  Cache lives at ``saved_projects/.cache/search_cache.sqlite3``
# and is separate from the LLM response cache (``llm_cache.sqlite3``).
# Per-provider TTLs reflect how quickly each source drifts: DDG news drifts
# fast, arXiv papers essentially never change.

# Master switch.  0 = no disk caching (in-memory per-query cache still
# applies for the duration of a single run).  1 = enable disk cache.
LIBRARIAN_SEARCH_DISK_CACHE_ENABLED=1

# Repo-relative or absolute path for the SQLite cache file.  Parent
# directory is auto-created.  Set to a custom location if you want to
# share the cache between multiple Crucible installations.
LIBRARIAN_SEARCH_CACHE_PATH=saved_projects/.cache/search_cache.sqlite3

# Per-provider TTL (hours).  Tune downward if you observe stale results
# for a fast-moving domain; upward to maximise cache reuse for a stable
# domain.  Apply to entries written AFTER the change; old entries keep
# their original TTL until naturally evicted.
LIBRARIAN_SEARCH_CACHE_TTL_DDG_HOURS=12
LIBRARIAN_SEARCH_CACHE_TTL_GITHUB_HOURS=24
LIBRARIAN_SEARCH_CACHE_TTL_ARXIV_HOURS=168
LIBRARIAN_SEARCH_CACHE_TTL_CONTEXT7_HOURS=6

# =============================================================================
# Web Research Hardening — Provider Resilience (v1.1.8 extended)
# =============================================================================
# Adaptive cooldown + fallback chain + per-provider health observability.
# Replaces the legacy "hardcoded 4-second sleep + 3-strike circuit breaker"
# pattern with one that reacts to actual rate-limit signals (429 / 202 from
# DuckDuckGo bot-detection) and routes around stuck providers transparently.

# Initial cooldown when a provider returns 429 / 202.  Doubles on each
# subsequent trigger up to LIBRARIAN_PROVIDER_COOLDOWN_MAX_SECONDS.  During
# cooldown the provider is skipped entirely; the fallback chain (if
# enabled) routes to the next-priority provider for that query class.
LIBRARIAN_PROVIDER_COOLDOWN_INITIAL_SECONDS=60
LIBRARIAN_PROVIDER_COOLDOWN_MAX_SECONDS=1800

# Enable the per-query-class fallback chain.  When a primary provider
# returns empty results or hits cooldown, the dispatcher auto-routes to
# the next provider in the same class (general web / code / academic /
# docs).  0 = silos behave as in v1.1.7 (each provider stands alone;
# no automatic fallback).
LIBRARIAN_PROVIDER_FALLBACK_ENABLED=1

# Async provider fan-out.  When enabled, the dispatcher uses asyncio +
# per-provider Semaphore to fire all providers for one query in parallel
# (subject to per-provider concurrency caps).  Single biggest librarian
# wall-clock win — typical runs drop 60%+.  0 = fall back to sequential
# dispatch (legacy v1.1.7 behaviour) for emergency rollback.
LIBRARIAN_ASYNC_FANOUT_ENABLED=1

# Cross-provider query deduplication.  Same normalised query string sent
# to multiple providers within the same query class is sent only once,
# followed by fallback chain if the first returns empty.  Saves ~30% of
# HTTP calls in typical runs.
LIBRARIAN_CROSS_PROVIDER_DEDUP_ENABLED=1

# Emit per-provider health summary at the end of the librarian stage
# covering request count, 200 OK count, 429/202 count, timeout count,
# citation yield.  Also written to .crucible_insights/output.jsonl as
# a ``provider_health_summary`` event for v1.2.0 retrieval.
LIBRARIAN_PROVIDER_HEALTH_SUMMARY=1

# HTTP/2 + keep-alive connection reuse for outbound provider calls.
# Reduces per-request connection-setup cost by 10-20%.  Some self-hosted
# SearXNG instances do not speak HTTP/2; set HTTP2 to 0 if you observe
# TLS handshake errors against those.
LIBRARIAN_HTTP2_ENABLED=1
LIBRARIAN_HTTP_KEEPALIVE_ENABLED=1

# =============================================================================
# Web Research Hardening — Additional Providers (v1.1.8 extended)
# =============================================================================
# Adds three zero-auth providers on top of the existing core list
# (websearch, context7, github, arxiv, paperswithcode; v1.1.10 removed
# grep_app from the default — Vercel Bot Protection now blocks all
# unauthenticated grep.app requests with a JS PoW challenge).  None
# require API keys.  They fill citation gaps that DDG + arXiv miss,
# especially for CJK-language quant topics and for niche academic claims.
#
# Provider notes:
#   - openalex   100k req/day free, global academic papers, CJK-friendly
#   - crossref   Unlimited polite pool, DOI metadata, cross-discipline
#   - wikipedia  Unlimited, definitional baseline and Tier-1 anchors
#   - searxng    Federated meta-search via PUBLIC instances; variable
#                reliability so NOT in the default list.  Opt in only
#                after confirming an instance you trust.
#   - tavily     AI-optimised commercial web search (v1.1.13).  REQUIRES a
#                real TAVILY_API_KEY (see Librarian Provider Authentication
#                above).  Sits before searxng in the general fallback chain.
#
# Each provider also goes through the fallback chain + cooldown + cache
# layers above, so adding them costs nothing if they return empty.

LIBRARIAN_EXTRA_PROVIDERS=openalex,crossref,wikipedia

# To enable SearXNG as a fourth fallback, uncomment and customise the
# line below.  See domain_pins.json for example SearXNG instance hosts.
# LIBRARIAN_EXTRA_PROVIDERS=openalex,crossref,wikipedia,searxng

# To enable Tavily (set a real TAVILY_API_KEY above first), add ``tavily`` to
# the extras list.  Combine with searxng if you want both as fallbacks.
# LIBRARIAN_EXTRA_PROVIDERS=openalex,crossref,wikipedia,tavily
# LIBRARIAN_EXTRA_PROVIDERS=openalex,crossref,wikipedia,tavily,searxng

# =============================================================================
# Web Research Hardening — Query Quality (v1.1.8 extended)
# =============================================================================
# Two upstream improvements that materially raise citation quality:
#
# 1. Domain authoritative-source pinning.  For ``mode=quant`` topics that
#    touch crypto / tradfi / a known scientific subdomain, the librarian
#    pre-fetches a small set of operator-curated URLs (Binance docs,
#    Wikipedia Sharpe ratio definition, etc.) BEFORE search.  These enter
#    the citation pool as Tier-1 anchors before any DDG/arXiv result gets
#    a chance to dominate.  Pins are defined in JSON (the repo does not
#    use PyYAML).
# 2. Bilingual query expansion.  When a CJK query returns fewer than
#    LIBRARIAN_BILINGUAL_QUERY_THRESHOLD native-language citations, the
#    librarian auto-issues an English mirror of the query.  Cross-language
#    result metadata is merged so the same paper found via Chinese title
#    and English title only counts as one citation.

LIBRARIAN_DOMAIN_PINS_ENABLED=1
LIBRARIAN_DOMAIN_PINS_PATH=crucible/config/domain_pins.json

LIBRARIAN_BILINGUAL_QUERY_EXPANSION=1

# Auto-translate CJK queries only when the native-language result count
# is below this threshold.  Saves LLM cost when the native search
# succeeds on its own.  Range 1-10; default 3.
LIBRARIAN_BILINGUAL_QUERY_THRESHOLD=3

# Which LLM model handles the CJK to English translation.  Empty value
# means reuse the librarian model (OPENROUTER_LIBRARIAN_MODEL etc).
# Override if you have a smaller / cheaper model for translation only.
LIBRARIAN_QUERY_TRANSLATE_MODEL=

# Per-direction claim attribution.  When enabled, the librarian also
# tags each claim with the direction key (A..G) and decision field
# (thesis / primary_metric / fastest_test / major_risk / data_sources)
# it anchors to.  The evidence auditor consumes these tags to populate
# ``supported_fields`` — without this, ``supported_fields`` is empty for
# every direction and the force-none gate always triggers (see v1.1.8
# diagnostic).  Disable only if you suspect a librarian-prompt regression
# during rollout.
LIBRARIAN_CLAIM_ATTRIBUTION_DIRECTION_KEY=1

# =============================================================================
# Direction Gate Tuning (v1.1.8 extended)
# =============================================================================
# v1.1.7 force-none gate is strict: if all short-listed directions have
# ``unsupported_count >= 3`` or ``evidence_score == 0`` the gate kills the
# entire pipeline and returns no output.  For niche topics where Tier-1
# cross-validated sources do not exist, the gate is over-aggressive.
#
# The degrade-not-die path below allows the gate to pick the
# highest-scoring direction even when all are clamped to 0, AND mark it
# ``low confidence`` instead of force-none, AFTER N consecutive
# refinement iterations all hit the same structural failure.  Hard
# feasibility failures (``hard_feasibility_pass=False``) are NEVER
# downgraded — those signal genuine physical infeasibility.
#
# This control is ORTHOGONAL to CRUCIBLE_DEBATE_AUDIT_MODE: audit mode is
# observation-only and does not change pipeline behaviour; the toggle
# here is the only knob that actually changes the gate's decision path.

# Master switch.  0 = legacy v1.1.7 force-none behaviour (default,
# conservative).  1 = enable degrade-not-die after N iterations.  P5
# observability still emits a ``direction_debate_degraded_proceed``
# ledger event regardless of the switch, so v1.2.0 retrieval can see
# which runs would have triggered.
CRUCIBLE_DEBATE_TOLERATE_UNVERIFIABLE_EVIDENCE=0

# Number of consecutive force-none iterations (with the same gate
# reason) that triggers the degrade path.  Range 1-5; default 3 matches
# the DIRECTION_REFINEMENT_MAX_ITERATIONS+1 ceiling so the degrade only
# fires when refinement has fully exhausted its budget.
CRUCIBLE_DEBATE_DEGRADE_AFTER_N_ITERATIONS=3
