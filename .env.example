# Copy this file to .env before running the mainline workflow.

# LLM provider selection.
# Supported values: openrouter | alibaba_coding_plan | ollama
LLM_PROVIDER=openrouter

# Required when LLM_PROVIDER=openrouter: OpenRouter API key used by the workflow.
OPENROUTER_API_KEY=replace_with_openrouter_api_key

# OpenRouter base URL.  Change only if using a proxy.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter main workflow model.
OPENROUTER_PRIMARY_MODEL=z-ai/glm-5.1

# OpenRouter Stage 0 direction judge model.
OPENROUTER_DIRECTION_JUDGE_MODEL=z-ai/glm-5.1

# OpenRouter librarian / research model.
OPENROUTER_LIBRARIAN_MODEL=minimax/minimax-m2.5

# Required when LLM_PROVIDER=alibaba_coding_plan: Alibaba Coding Plan API key.
ALIBABA_CODING_PLAN_API_KEY=replace_with_alibaba_coding_plan_api_key

# Optional override for the official Alibaba Coding Plan OpenAI-compatible base URL.
ALIBABA_CODING_PLAN_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1

# Alibaba Coding Plan main workflow model.
ALIBABA_CODING_PLAN_PRIMARY_MODEL=glm-5

# Alibaba Coding Plan Stage 0 direction judge model.
ALIBABA_CODING_PLAN_DIRECTION_JUDGE_MODEL=glm-5

# Alibaba Coding Plan librarian / research model.
ALIBABA_CODING_PLAN_LIBRARIAN_MODEL=qwen3.5-plus

# Optional Alibaba Coding Plan timeout overrides.
# ALIBABA_CODING_PLAN_LLM_TIMEOUT_SECONDS=180
# ALIBABA_CODING_PLAN_INITIAL_RESPONSE_TIMEOUT_SECONDS=120

# Required when LLM_PROVIDER=ollama: Ollama local LLM server settings.
# Ollama must be running locally (https://ollama.ai).  No API key is required.
OLLAMA_BASE_URL=http://localhost:11434/v1

# Ollama main workflow model (must be pulled: ollama pull llama3.2).
OLLAMA_PRIMARY_MODEL=llama3.2

# Ollama Stage 0 direction judge model.
OLLAMA_DIRECTION_JUDGE_MODEL=llama3.2

# Ollama librarian / research model.
OLLAMA_LIBRARIAN_MODEL=llama3.2

# Optional request timeout in seconds.
OPENROUTER_LLM_TIMEOUT_SECONDS=900

# Minimum delay (seconds) between consecutive web-search HTTP requests.
# Increase if DuckDuckGo or other providers return 429 / block responses.
# Minimum allowed: 0.5. Default: 4.
# LIBRARIAN_INTER_QUERY_DELAY_SECONDS=4

# Optional: override env file path.
# CRUCIBLE_ENV_FILE=.env

# Optional output controls.
# STRICT_JSON=1
# COST_TRACE=1
# LOCAL_CACHE=1
# CRUCIBLE_LOG_LEVEL=INFO
# CRUCIBLE_JSON_LOGS=0

# ---------- Agent Retry & Backoff ----------
# Controls how resilience.py retries failed agent crew kickoffs.
# AGENT_KICKOFF_RETRY_ATTEMPTS=20
# AGENT_KICKOFF_RETRY_BACKOFF_SECONDS=2.0
# AGENT_KICKOFF_RETRY_MAX_BACKOFF_SECONDS=30.0
# AGENT_KICKOFF_RETRY_JITTER_RATIO=0.15

# Optional runtime validation override.
# CODEX_ENTRYPOINT=api/main.py:app

# Optional API version check.
# API_VERSION_CHECK_ENABLED=1
# API_VERSION_CHECK_MAX_LIBRARIES=5
# API_VERSION_CHECK_TIMEOUT_SECONDS=60
# API_VERSION_CHECK_CACHE_TTL_HOURS=24
# API_VERSION_CHECK_SEVERITY_THRESHOLD=medium

# Optional direction research refinement inside Direction Debate evidence-gap
# handling. This does not enable Stage 0 Direction Debate by itself.
# DIRECTION_REFINEMENT_ENABLED=1
# DIRECTION_REFINEMENT_MAX_ITERATIONS=2

# Master switch for the Gate Controller subsystem (section_06).
# Set to 0 to completely disable Gate Controller evaluation on every run.
# Default: 1 (enabled). Disabling also suppresses selective reruns.
# GATE_CONTROL_ENABLED=1

# Master switch for the Selective Rerun subsystem.
# Set to 0 to disable all selective reruns even when GATE_CONTROL_ENABLED=1.
# Default: 1 (enabled).
# SELECTIVE_RERUN_ENABLED=1

# Optional: allow Gate Controller to bounce analysis back for refinement
# when the Gate Controller / selective rerun flow is enabled.
# Set to 1 to allow feedback loops, or 0 to force Gate Controller to keep the
# current decision without bounce-back.
# Evidence-insufficient feedback can reopen Direction Debate only when the CLI
# explicitly enables it with --direction-debate / --direction-debate-only.
# Detail-insufficient feedback only reruns the Gate-named analyst roles.
# The feedback loop is capped at 2 bounce attempts.
# GATE_DIRECTION_FEEDBACK_ENABLED=1

# Optional: true selective rerun upper bound for analysis crew reruns.
# This is separate from DIRECTION_REFINEMENT_MAX_ITERATIONS.
# SELECTIVE_RERUN_MAX_ATTEMPTS=5

# =============================================================================
# Budget & Cost Limits (section_06_runtime_quality_api.py)
# =============================================================================
# Soft cost warning threshold in USD.  When cumulative run cost exceeds this
# value the pipeline logs a WARNING and continues.  Leave unset to disable.
# BUDGET_SOFT_COST_LIMIT=

# Hard cost cutoff in USD.  When cumulative run cost exceeds this value the
# pipeline raises a BudgetExceededError and stops immediately.  Leave unset
# to disable.  Recommended for automated/scheduled batch runs.
# BUDGET_HARD_COST_LIMIT=

# Maximum total tokens (input + output) allowed for a single run across all
# LLM calls.  Leave unset to disable.
# BUDGET_MAX_TOTAL_TOKENS=

# =============================================================================
# Convergence Guard (convergence_guard.py)
# =============================================================================
# Hard cap on the number of agent tick() calls per run.  0 disables.
# Default: 50.
# CONVERGENCE_MAX_ITERATIONS=50

# Wall-clock timeout in seconds for the convergence guard.  0 disables.
# Default: 3600 (1 hour).
# CONVERGENCE_TIMEOUT_SECONDS=3600

# Emit StaleLoopWarning when the same agent output signature is seen this
# many times consecutively.  0 disables stale detection.  Default: 5.
# CONVERGENCE_STALE_THRESHOLD=5

# =============================================================================
# Enhanced runner (run_crucible_enhanced.py) feature settings
# =============================================================================

# --- Security scan (features/security_scan.py) --------------------------------
# Run static security analysis (bandit if installed, else pattern-based)
# on generated code after each run. Set to 0 to disable.
# ENHANCED_SECURITY_SCAN=1

# --- Deployment artifact generation (features/deployment_artifacts.py) --------
# Generate Dockerfile, docker-compose.yml, .env.example, alembic.ini, and
# .github/workflows/ci.yml from generated code after each run.
# ENHANCED_DEPLOYMENT_ARTIFACTS=1

# --- Project memory (features/project_memory.py) ------------------------------
# Save direction decisions, failed experiments, and blocking risks across runs
# so future runs can avoid repeating past mistakes.
# File: {workspace}/project_memory.json
# ENHANCED_PROJECT_MEMORY=1
# Max entries retained per project (oldest are evicted).
# ENHANCED_PROJECT_MEMORY_MAX_ENTRIES=10

# --- Test generation (features/test_generator.py) -----------------------------
# Generate a pytest test suite for each generated Python file using the LLM.
# Disabled by default; enable with --generate-tests or set to 1 here.
# NOTE: Requires a working LLM (uses init_llm() from the runtime).
# ENHANCED_GENERATE_TESTS=0
# Maximum number of source files to generate tests for per run.
# ENHANCED_GENERATE_TESTS_MAX_FILES=20

# --- API version auto-patch (features/api_version_autopatch.py) ---------------
# Automatically patch deprecated API calls detected by the API version check.
# Disabled by default; enable with --api-autopatch or set to 1 here.
# NOTE: Requires a working LLM and API_VERSION_CHECK_ENABLED=1.
# ENHANCED_API_AUTOPATCH=0

# --- Independent validation (features/independent_validator.py) ----------------
# Run independent subprocess validation (syntax/pytest/smoke) and optional
# LLM adversarial code review after code generation.
# ENHANCED_INDEPENDENT_VALIDATION=0
# Control whether the adversarial LLM review phase is enabled when
# independent validation is active (set 0 to run subprocess checks only).
# ENHANCED_INDEPENDENT_VALIDATION_LLM=1
# Subprocess timeout in seconds for pytest and smoke check phases.
# ENHANCED_INDEPENDENT_VALIDATION_TIMEOUT=60

# --- CI/CD output (features/ci_cd.py) -----------------------------------------
# Write github_annotations.txt and ci_summary.md after each run.
# Automatically activates when GITHUB_ACTIONS=true.
# ENHANCED_CI_OUTPUT=0

# --- Watch mode defaults (features/watch_mode.py) -----------------------------
# Default debounce delay in seconds for watch subcommand.
# ENHANCED_WATCH_DEBOUNCE_SECONDS=30

# --- Batch runner defaults (features/batch_runner.py) -------------------------
# Default max parallel workers for batch subcommand (1 = sequential).
# ENHANCED_BATCH_MAX_WORKERS=1
# Per-project subprocess timeout in seconds for the batch subcommand.
# ENHANCED_BATCH_TIMEOUT=3600

# --- Watch mode timeout --------------------------------------------------------
# Per-triggered-run subprocess timeout in seconds for the watch subcommand.
# If a file-change-triggered run exceeds this limit the process is killed and
# watch mode continues watching for the next change.  Default: 3600.
# ENHANCED_WATCH_TIMEOUT=3600

# --- Auto-remediation (features/auto_remediator.py) ---------------------------
# Closed-loop LLM-driven fix for security and validation HIGH+ findings.
# Disabled by default; enable with --auto-remediation or set to 1 here.
# NOTE: Requires a working LLM.
# ENHANCED_AUTO_REMEDIATION=0
# Maximum fix iterations (each round re-scans after applying patches).
# ENHANCED_AUTO_REMEDIATION_MAX_ROUNDS=3

# --- Dependency audit (features/dependency_auditor.py) ------------------------
# Run pip-audit against generated requirements.txt for CVE detection.
# ENHANCED_DEPENDENCY_AUDIT=0

# --- Notification hooks (features/notification_hooks.py) ----------------------
# Send notifications when a pipeline run completes.
# NOTIFY_WEBHOOK_URL=
# NOTIFY_SLACK_WEBHOOK_URL=
# NOTIFY_DISCORD_WEBHOOK_URL=
# Only send notifications on failure (set to 1 to enable).
# NOTIFY_ON_FAIL_ONLY=0

# --- HTML report export (features/report_exporter.py) -------------------------
# Generate a self-contained HTML report combining all run artifacts.
# ENHANCED_HTML_REPORT=0

# --- Code quality metrics (features/code_quality.py) --------------------------
# Run AST-based code quality analysis (complexity, LOC, nesting depth).
# ENHANCED_CODE_QUALITY=0

# --- Run history registry (features/run_registry.py) -------------------------
# Index completed runs into a SQLite registry for cross-run queries.
# ENHANCED_RUN_REGISTRY=0

# --- Interactive mode (features/interactive_mode.py) --------------------------
# Pause before each run and collect research guidance (focus areas, constraints,
# hypotheses) via stdin.  No-op in non-TTY / CI environments.
# ENHANCED_INTERACTIVE=0

# --- Backtest runner (features/backtest_runner.py) ----------------------------
# Run automated backtest pipeline: data prep, execution, param sweep, LLM fix loop.
# Enable with --backtest-runner or set to 1 here.
# ENHANCED_BACKTEST_RUNNER=0

# --- Document ingestion (run subcommand --ingest-docs) -------------------------
# Inject local documents (PDF/MD/TXT/DOCX) into the pipeline context.
# Enable with --ingest-docs or set to 1 here.
# ENHANCED_INGEST_DOCS=0
# Directory of documents to ingest (read by --ingest-docs).
# ENHANCED_INGEST_DOCS_DIR=

# --- GitHub repository analysis (--github-repo) --------------------------------
# GitHub repository URL to analyse and inject as research context.
# ENHANCED_GITHUB_REPO=

# --- Multi-language codegen (features/multilang_codegen.py) -------------------
# Generate TypeScript/Go translations of Stage 4 Python output.
# Enable with --multilang-codegen or set to 1 here.
# ENHANCED_MULTILANG_CODEGEN=0
# Comma-separated target languages (default: typescript,go).
# ENHANCED_MULTILANG_LANGS=typescript,go

# --- Post-analysis chat (features/post_analysis_chat.py) ----------------------
# Start interactive Q&A about the analysis after the run completes.
# Enable with --post-chat or set to 1 here.
# ENHANCED_POST_CHAT=0

# --- Agent performance metrics (features/agent_metrics.py) --------------------
# Compute and display per-agent token, latency, and task metrics after the run.
# Enable with --agent-metrics or set to 1 here.
# ENHANCED_AGENT_METRICS=0

# --- Prompt version tracking (--prompt-version-label) -------------------------
# Label recorded alongside the run's quality score for A/B prompt comparisons.
# ENHANCED_PROMPT_VERSION_LABEL=

# --- Lock-file generation (features/lockfile_gen.py) --------------------------
# Generate pyproject.toml + pinned requirements.txt for generated code.
# Enable with --lockfile-gen or set to 1 here.
# ENHANCED_LOCKFILE_GEN=0

# --- Semantic run deduplication (features/run_deduplication.py) ---------------
# Check for semantically similar past runs before starting.  Prompts for
# confirmation when a similar run is detected.
# ENHANCED_DEDUP_CHECK=0
# Cosine similarity threshold [0.0, 1.0] for flagging a run as duplicate.
# DEDUP_SIMILARITY_THRESHOLD=0.85
# Only consider runs within the last N days (0 = no time limit).
# DEDUP_LOOKBACK_DAYS=30
# Maximum number of past runs included in the similarity corpus.
# DEDUP_MAX_CORPUS_RUNS=100

# --- External data connectors (features/external_data_connectors.py) ----------
# Fetch real market data from Alpha Vantage, CoinGecko, or FRED and write to
# {run_dir}/code/data/ before backtest_runner executes.
# Enable via --external-data coingecko,fred or set individual API keys below.
#
# Alpha Vantage (required for alpha_vantage source):
# ALPHA_VANTAGE_API_KEY=replace_with_alpha_vantage_key
# ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co
#
# FRED / Federal Reserve Economic Data (optional; increases rate limits):
# FRED_API_KEY=replace_with_fred_key
# FRED_BASE_URL=https://api.stlouisfed.org
#
# CoinGecko (no API key required for free tier):
# COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
#
# HTTP fetch settings shared across all connectors:
# EXTERNAL_DATA_TIMEOUT=30
# EXTERNAL_DATA_MAX_RETRIES=3

# --- GitHub repo analyser (features/github_repo_analyzer.py) ------------------
# HTTP timeout in seconds for GitHub API requests.
# GITHUB_ANALYZER_TIMEOUT=15
# Max retry attempts on transient errors (429/5xx).
# GITHUB_ANALYZER_MAX_RETRIES=2
# Seconds to cache GitHub API responses (0 = disable).
# GITHUB_ANALYZER_CACHE_TTL=3600

# --- Document ingestion (features/document_ingestion.py) ----------------------
# Max characters read from a single ingested document.
# DOCUMENT_INGESTION_MAX_CHARS=8000
# Max total characters across all ingested documents per run.
# DOCUMENT_INGESTION_TOTAL_CHARS=24000

# --- Multi-language codegen (features/multilang_codegen.py) -------------------
# Enable via --multilang-codegen flag.
# Max Python files translated per run.
# MULTILANG_MAX_FILES=10
# Max chars of source code sent per file to the LLM.
# MULTILANG_MAX_CHARS=4000
# Set to 1 to allow Rust 2021 edition as a target (experimental).
# MULTILANG_ENABLE_RUST=0

# --- Project memory prompt budget (features/project_memory.py) ----------------
# Max chars of project memory injected into the system prompt (~4 000 tokens).
# PROJECT_MEMORY_PROMPT_CHARS=16000

# --- Post-analysis chat context (features/post_analysis_chat.py) --------------
# Max chars of analysis output used as context for interactive chat.
# POST_CHAT_CONTEXT_CHARS=12000

# --- Project profile override (features/project_profile.py) ------------------
# Absolute path to a JSON project profile file. Auto-detected when blank.
# PIPELINE_PROJECT_PROFILE=

# --- Prompt A/B testing (features/prompt_ab_test.py) -------------------------
# Use the 'abtest' subcommand to compare two pipeline prompt variants.
# Maximum seconds for each pipeline subprocess in an A/B test run.
# AB_TEST_TIMEOUT=3600
# Set to 1 to run both variants in parallel (uses more resources).
# AB_TEST_PARALLEL=0

# =============================================================================
# Backtest parameter search (crucible/features/backtest_runner.py)
# =============================================================================

# Search strategy for hyperparameter optimisation.
# Supported values: grid | random | bayesian
# "bayesian" uses Optuna TPE sampler (requires: pip install optuna).
# BACKTEST_PARAM_SEARCH=grid

# Number of Optuna trials when BACKTEST_PARAM_SEARCH=bayesian.
# BACKTEST_BAYESIAN_N_TRIALS=30

# =============================================================================
# Portfolio backtest (crucible/features/portfolio_backtest.py)
# =============================================================================

# Rebalancing frequency applied to the combined portfolio curve.
# Supported values: daily | weekly | monthly | quarterly | annual
# PORTFOLIO_REBALANCE_PERIOD=monthly

# Annualised risk-free rate used for Sharpe / Sortino ratio calculations.
# PORTFOLIO_RISK_FREE_RATE=0.04

# =============================================================================
# MLflow experiment tracking (crucible/features/mlflow_sink.py)
# =============================================================================

# MLflow tracking server URI.  When set, every pipeline run is automatically
# logged as an MLflow experiment run (requires: pip install mlflow).
# MLFLOW_TRACKING_URI=http://localhost:5000

# MLflow experiment name (default: Crucible).
# MLFLOW_EXPERIMENT_NAME=Crucible

# Set to 1 to upload the HTML report as an MLflow artifact on pipeline.complete.
# MLFLOW_LOG_ARTIFACTS=0

# =============================================================================
# WebUI display language
# =============================================================================

# Display language for tooltips and inline help text in the WebUI.
# Values: en (English, default) or zh (Traditional Chinese).
# The toggle in the top-right corner of the WebUI updates this value
# automatically when clicked, so manual editing is rarely needed.
# WEBUI_LANGUAGE=en

# =============================================================================
# Webhook trigger (webui/app.py — POST /webhook/trigger)
# =============================================================================

# HMAC-SHA256 secret used to validate incoming webhook requests.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave blank to disable HMAC signature validation (not recommended in production).
# WEBHOOK_SECRET=

# =============================================================================
# Quant Analytics Suite — Walk-Forward, Signal, Regime, Monte Carlo, Factor,
# Risk Attribution, Transaction Cost, Tearsheet
# =============================================================================

# --- Feature enable flags (run_crucible_enhanced.py) -----------------------
# Run Walk-Forward + Significance Testing after a Quant mode backtest.
# Enable with --quant-analytics or set to 1 here.
# ENHANCED_QUANT_ANALYTICS=0
# Enable walk-forward validation within --quant-analytics (default: on when analytics enabled).
# ENHANCED_WALK_FORWARD=1
# Enable permutation/bootstrap significance test within --quant-analytics (default: on).
# ENHANCED_SIGNIFICANCE_TEST=1
# Detect market regimes (bull/bear/sideways) from backtest price data.
# ENHANCED_REGIME_DETECTION=0
# Run CAPM/Fama-French factor exposure regression.
# ENHANCED_FACTOR_ANALYSIS=0
# Run transaction cost sensitivity analysis.
# ENHANCED_TRANSACTION_COST=0
# Run Monte Carlo simulation and stress tests.
# ENHANCED_MONTE_CARLO=0
# Generate rich Markdown strategy tearsheet integrating all reports.
# ENHANCED_TEARSHEET=0
# Run signal decay analysis to measure edge half-life.
# ENHANCED_SIGNAL_ANALYSIS=0
# Run cointegration + pairs trading analysis on multi-asset data.
# ENHANCED_COINTEGRATION=0
# Compute rolling correlation matrix and PCA decomposition.
# ENHANCED_DYNAMIC_CORRELATION=0

# --- Walk-forward validation (quant_analytics.py) ----------------------------
# WALK_FORWARD_N_SPLITS=5
# WALK_FORWARD_OOS_PCT=0.3
# WALK_FORWARD_IS_PCT=1
# WALK_FORWARD_MIN_TRAIN_BARS=100

# --- Signal analysis (quant_analytics.py / signal_analyzer.py) ---------------
# SIGNAL_HORIZONS=1,2,3,5,10,20,40
# SIGNAL_MIN_OBSERVATIONS=30
# SIGNAL_SIGNIFICANCE_THRESH=0.05
# SIG_N_PERMUTATIONS=1000
# SIG_N_BOOTSTRAP=1000
# SIG_CONFIDENCE_LEVEL=0.95

# --- Regime detection (regime_detector.py) ------------------------------------
# REGIME_METHOD=volatility
# REGIME_N_REGIMES=3
# REGIME_VOL_WINDOW=20
# REGIME_TREND_WINDOW=50
# REGIME_LOOKBACK_BARS=0

# --- Monte Carlo simulation (monte_carlo.py) ----------------------------------
# MC_N_SIMULATIONS=5000
# MC_HORIZON_DAYS=252
# MC_METHOD=bootstrap
# MC_SEED=42

# --- Factor analysis (factor_analyzer.py) -------------------------------------
# FACTOR_RISK_FREE_RATE=0.04
# FACTOR_LOOKBACK_DAYS=252
# FACTOR_USE_FF_DATA=0

# --- Risk attribution (risk_attribution.py) -----------------------------------
# Enable --risk-attribution by default on every run without passing the flag.
# ENHANCED_RISK_ATTRIBUTION=0
# RISK_METHOD=historical
# RISK_CONFIDENCE_LEVEL=0.95
# RISK_LOOKBACK_WINDOW=252

# --- Transaction cost model (transaction_cost_model.py) -----------------------
# TC_COMMISSION_PCT=0.001
# TC_SLIPPAGE_PCT=0.0005
# TC_SPREAD_BPS=2.0
# TC_USE_KYLE_IMPACT=0
# TC_KYLE_LAMBDA=0.1
# TC_AVG_DAILY_VOLUME=0
# TC_N_SCENARIOS=10

# --- Tearsheet report (tearsheet.py) -----------------------------------------
# TEARSHEET_MONTHLY_RETURNS=1
# TEARSHEET_DRAWDOWN_PERIODS=1
# TEARSHEET_MAX_DRAWDOWN_PERIODS=5
# TEARSHEET_TRADE_ANALYSIS=1

# =============================================================================
# Backtest runner (crucible/features/backtest_runner.py)
# =============================================================================

# BACKTEST_SYMBOL=SPY
# BACKTEST_DATA_SOURCE=auto
# BACKTEST_PERIOD=auto
# BACKTEST_INTERVAL=auto
# BACKTEST_DATA_ROWS=500
# BACKTEST_INITIAL_CAPITAL=100000
# BACKTEST_MAX_COMBOS=50
# BACKTEST_TARGET_METRIC=sharpe_ratio
# BACKTEST_FIX_MAX_ROUNDS=3
# BACKTEST_TIMEOUT=120

# =============================================================================
# v16.9 Feature Bundle  (--v169-features LIST  or  V169_FEATURES env var)
# =============================================================================
# Comma-separated list of features to activate in one run, e.g.:
# V169_FEATURES=model_cascade,semantic_cache,llm_quality_scorer,prometheus_exporter
# V169_FEATURES=

# --- Multi-language code generation (multilang_codegen.py) -------------------
# Enable Julia 1.9+ as an additional codegen target.
# MULTILANG_ENABLE_JULIA=0

# --- Model cascade / cost optimiser (model_cascade.py) ----------------------
# MODEL_CASCADE_ENABLED=1
# MODEL_CASCADE_CHEAP_MODEL=openai/gpt-4o-mini
# MODEL_CASCADE_MID_MODEL=openai/gpt-4o
# MODEL_CASCADE_EXPENSIVE_MODEL=anthropic/claude-opus-4-5
# MODEL_CASCADE_COST_THRESHOLD_USD=0.10

# --- Semantic cache (semantic_cache.py) --------------------------------------
# SEMANTIC_CACHE_ENABLED=1
# SEMANTIC_CACHE_THRESHOLD=0.85
# SEMANTIC_CACHE_MAX_HISTORY=50

# --- Few-shot injector (few_shot_injector.py) --------------------------------
# FEW_SHOT_ENABLED=1
# FEW_SHOT_MIN_SCORE=75
# FEW_SHOT_MAX_EXAMPLES=3

# --- Global knowledge base (global_knowledge_base.py) ------------------------
# GLOBAL_KB_ENABLED=1
# GLOBAL_KB_MIN_SCORE=60
# GLOBAL_KB_MAX_ENTRIES_PER_RUN=10
# GLOBAL_KB_MAX_RETRIEVE=5

# --- LLM quality scorer (llm_quality_scorer.py) ------------------------------
# LLM_QUALITY_SCORER_ENABLED=1
# LLM_QUALITY_SCORER_MIN_PASS=60

# --- Options analyser / Black-Scholes (options_analyzer.py) ------------------
# OPTIONS_SPOT_PRICE=100
# OPTIONS_RISK_FREE_RATE=0.05
# OPTIONS_VOLATILITY=0.20
# OPTIONS_STRIKES_RANGE=0.8,0.9,1.0,1.1,1.2
# OPTIONS_MATURITIES_DAYS=7,30,60,90,180,365

# --- Alternative data connectors (alt_data_connectors.py) --------------------
# ALT_DATA_SYMBOL=SPY
# ALT_DATA_NEWSAPI_ENABLED=1
# ALT_DATA_REDDIT_ENABLED=1
# ALT_DATA_FRED_ENABLED=1
# NEWS_API_KEY=                        # newsapi.org key (optional)
# FRED_API_KEY=                        # FRED API key for higher rate limits (optional)

# --- Market data stream (market_stream.py) -----------------------------------
# MARKET_STREAM_SYMBOLS=auto           # comma-separated tickers, or 'auto' to detect
# MARKET_STREAM_SNAPSHOT_ONLY=1

# --- Trading platform adapters (trading_platform.py) -------------------------
# TRADING_PLATFORM_TARGETS=alpaca,binance   # alpaca | binance | ibkr
# TRADING_PAPER_MODE=true              # 'true' = block live orders (recommended)
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets
# BINANCE_API_KEY=
# BINANCE_SECRET_KEY=
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497
# IBKR_CLIENT_ID=1

# --- Job scheduler (scheduler.py) -------------------------------------------
# SCHEDULER_ENABLED=1
# SCHEDULER_CRON=0 8 * * 1-5          # weekdays 08:00 UTC
# SCHEDULER_TIMEZONE=UTC

# --- YAML pipeline config (yaml_pipeline.py) ---------------------------------
# YAML_PIPELINE_ENABLED=1
# YAML_PIPELINE_CONFIG=pipeline.yaml

# --- Multi-project comparison (multi_project_compare.py) ---------------------
# COMPARE_ENABLED=1
# COMPARE_MAX_RUNS=10

# --- Citation verifier (citation_verifier.py) --------------------------------
# CITATION_VERIFY_ENABLED=1
# CITATION_VERIFY_MAX_URLS=20

# --- Webhook templates (webhook_templates.py) --------------------------------
# N8N_WEBHOOK_URL=
# ZAPIER_WEBHOOK_URL=
# PAGERDUTY_WEBHOOK_URL=
# PAGERDUTY_ROUTING_KEY=
# OPSGENIE_WEBHOOK_URL=
# TEAMS_WEBHOOK_URL=

# --- Config wizard (config_wizard.py) ----------------------------------------
# CONFIG_WIZARD_ENABLED=1

# --- Prometheus exporter (prometheus_exporter.py) ----------------------------
# PROMETHEUS_ENABLED=1
# PROMETHEUS_JOB_NAME=quantsaas
# PROMETHEUS_PUSHGATEWAY_URL=          # e.g. http://localhost:9091

# --- Grafana dashboard (grafana_dashboard.py) --------------------------------
# GRAFANA_ENABLED=1
# GRAFANA_DATASOURCE_UID=prometheus

# --- Redis cache (redis_cache.py) -------------------------------------------
# REDIS_CACHE_ENABLED=1
# REDIS_URL=redis://localhost:6379/0
# REDIS_CACHE_TTL_HOURS=24
# REDIS_CACHE_KEY_PREFIX=quantsaas:

# --- Celery distributed worker (celery_worker.py) ----------------------------
# CELERY_ENABLED=1
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1
# CELERY_WORKER_CONCURRENCY=4

# --- WebUI authentication (auth_manager.py) ----------------------------------
# AUTH_ENABLED=0
# AUTH_ADMIN_USER=admin
# AUTH_TOKEN_TTL_HOURS=24
# JWT_SECRET=                          # auto-generated if blank

# --- Report annotations (report_annotations.py) ------------------------------
# ANNOTATIONS_ENABLED=1
# ANNOTATIONS_AUTHOR=

# --- Notion / Obsidian export (notion_export.py) -----------------------------
# NOTION_API_KEY=                      # required for Notion push
# NOTION_DATABASE_ID=                  # required for Notion push
# NOTION_API_VERSION=2022-06-28

# --- Chat bots: Telegram + Discord (chat_bot.py) -----------------------------
# CHATBOT_ENABLED=1
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# CHATBOT_CHANNEL_ID=                  # Discord channel ID (optional)

# --- Docker sandbox executor (sandbox_executor.py) ---------------------------
# SANDBOX_ENABLED=1
# SANDBOX_DOCKER_IMAGE=python:3.11-slim
# SANDBOX_REQUIRE_DOCKER=0            # '1' = fail if Docker unavailable

# --- Type annotation coverage (type_coverage.py) ----------------------------
# TYPE_COVERAGE_ENABLED=1
# TYPE_COVERAGE_MIN_PCT=50
# TYPE_COVERAGE_RUN_MYPY=0            # '1' = also run mypy subprocess
