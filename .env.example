# --- Risk attribution (risk_attribution.py) -----------------------------------
# Enable --risk-attribution by default on every run without passing the flag.
# ENHANCED_RISK_ATTRIBUTION=0
# RISK_METHOD=historical
# RISK_CONFIDENCE_LEVEL=0.95
# RISK_LOOKBACK_WINDOW=252

# --- Transaction cost model (transaction_cost_model.py) -----------------------
# TC_COMMISSION_PCT=0.001
# TC_SLIPPAGE_PCT=0.0005
# TC_SPREAD_BPS=2.0
# TC_USE_KYLE_IMPACT=0
# TC_KYLE_LAMBDA=0.1
# TC_AVG_DAILY_VOLUME=0
# TC_N_SCENARIOS=10

# --- Tearsheet report (tearsheet.py) -----------------------------------------
# TEARSHEET_MONTHLY_RETURNS=1
# TEARSHEET_DRAWDOWN_PERIODS=1
# TEARSHEET_MAX_DRAWDOWN_PERIODS=5
# TEARSHEET_TRADE_ANALYSIS=1

# =============================================================================
# Backtest runner (crucible/features/backtest_runner.py)
# =============================================================================

# Refuse the synthetic-GBM fallback when set to 1 (default).  The backtest
# pipeline tries real-data providers in order: project data_provider.py →
# yfinance → ccxt / Binance.  When every provider fails (none installed, or
# no network, or invalid symbol) the cascade historically dropped to a
# random-walk synthetic dataset whose Sharpe / drawdown / win-rate numbers
# are statistically meaningless.  With this guard on, that fallback path
# raises BacktestDataIntegrityError instead, and the run surfaces a clear
# error pointing to the install command (pip install yfinance / ccxt) and
# the explicit opt-out below.  Only set to 0 for offline CI smoke tests or
# plumbing checks where strategy quality is not being evaluated.
BACKTEST_REQUIRE_REAL_DATA=1

# Minimum number of OHLCV rows a fetched dataset must contain before the
# backtest runner accepts it.  yfinance is known to return 1-2 stale rows
# for delisted / suspended tickers; treating those as success silently
# corrupts Sharpe / drawdown / win-rate metrics.  The threshold actually
# applied is max(BACKTEST_MIN_REAL_DATA_ROWS, 30% of the timeframe profile's
# synthetic_rows), so short intervals (1m) require more rows than long
# intervals (1d).  Set to a smaller value only for offline plumbing tests.
BACKTEST_MIN_REAL_DATA_ROWS=30

# Data cache: when a real-data provider succeeds, the CSV is written to
# ``$HOME/.crucible/data_cache/`` (or ``BACKTEST_DATA_CACHE_DIR``) keyed
# by ``sha1(symbol|period|interval)``.  Subsequent runs within the TTL
# window reuse the cache (no API call, no rate-limit risk).  TTL in
# hours; 0 disables caching.  v1.1.0 removed the date component from
# the cache key so APAC operators don't see a forced miss at 00:00 UTC.
BACKTEST_DATA_CACHE_TTL_HOURS=24
BACKTEST_DATA_CACHE_DIR=

# Maximum data staleness in days before the backtest report appends a
# warning.  Set to ``0`` to disable the staleness probe entirely (useful
# when intentionally evaluating against a historical window).
BACKTEST_DATA_MAX_STALENESS_DAYS=7

# Synthetic-data seed used when BACKTEST_REQUIRE_REAL_DATA is set to 0
# for plumbing smoke tests.  Integer = reproducible seed.  ``random`` =
# fresh seed each call.  The seed actually used is recorded in the
# report so a fluke run can be re-created.  Default ``42`` preserves
# the v1.0.x behaviour for any test code that depends on it.
BACKTEST_SYNTHETIC_SEED=42

# v1.1.0 fifth-pass (G-13): seed for ``_PARAM_RNG`` in
# ``backtest_runner`` driving the random-search fallback (when optuna
# is unavailable) and any ``strategy="random"`` parameter search.
# Integer = reproducible.  ``random`` = OS-time seed (legacy v1.0.x
# behaviour, NOT recommended for production — best_params would drift
# across re-runs of the same strategy code).  Default 4242.
BACKTEST_PARAM_SEED=4242

# v1.1.0 fifth-pass (G-14): hard wall-clock timeout for each
# yfinance / binance parallel-fetch worker future.  Caps the damage
# from a stalled or slowloris-style endpoint.  90 s is generous;
# decrease if you need faster failure on flaky providers.
BACKTEST_FETCH_HARD_TIMEOUT_SEC=90

# Dry-run flag: when ``1``, ``run_backtest_pipeline`` exits immediately
# after preparing data — no strategy execution, no parameter sweep.
# Useful for confirming that the data-fetch path is wired up without
# paying the cost of the full pipeline.  Off (0) by default.
BACKTEST_PREPARE_DATA_ONLY=0

# Optional parallel-fetch cascade.  When ``1``, the auto cascade fires
# yfinance and Binance concurrently and uses whichever returns valid
# data first.  Off by default — sequential cascade is friendlier to
# provider rate limits and easier to debug.  Enable only when you know
# the providers can handle the parallel load.
BACKTEST_PARALLEL_FETCH=0

# BACKTEST_SYMBOL=SPY
# BACKTEST_DATA_SOURCE=auto
# BACKTEST_PERIOD=auto
# BACKTEST_INTERVAL=auto
# BACKTEST_DATA_ROWS=500
# BACKTEST_INITIAL_CAPITAL=100000
# BACKTEST_MAX_COMBOS=50
# BACKTEST_TARGET_METRIC=sharpe_ratio
# BACKTEST_FIX_MAX_ROUNDS=3
# BACKTEST_TIMEOUT=120

# =============================================================================
