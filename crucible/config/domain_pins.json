{
  "version": 1,
  "description": "Domain authoritative-source pinning for the v1.1.8 librarian. When a user_problem matches one of these pins, the listed URLs are pre-fetched as Tier-1 anchors BEFORE search-provider dispatch. This guarantees the auditor has authoritative material to anchor direction-specific claims to (thesis / primary_metric / fastest_test / data_sources).\n\nMatch semantics:\n- ``mode`` is matched case-insensitively against the run mode (quant / saas / agent / scientist).\n- ``any_keyword`` is a list; the pin fires when ANY keyword appears as a case-insensitive substring of the lower-cased user_problem.\n- ``all_keywords`` (optional) is a list; the pin fires only when ALL listed keywords appear.\n- A pin with no keywords matches every problem in the given mode (use sparingly).\n\nLoader: ``crucible/web_research/domain_pins.py`` (added in v1.1.8 Phase 3). Format is JSON because the repo does not depend on PyYAML.",
  "pins": [
    {
      "id": "crypto_perpetuals",
      "label": "Crypto perpetual futures (Binance / Hyperliquid / general)",
      "match": {
        "mode": "quant",
        "any_keyword": [
          "binance",
          "hyperliquid",
          "perpetual",
          "perp futures",
          "funding rate",
          "資金費率",
          "永續合約",
          "永续合约"
        ]
      },
      "pre_fetch": [
        {
          "url": "https://binance-docs.github.io/apidocs/futures/en/",
          "tier": "Tier-1",
          "label": "Binance USDS-M Futures API reference",
          "subject_hint": "funding rate mechanism, mark-price klines, paged-history limits"
        },
        {
          "url": "https://www.binance.com/en/support/faq/introduction-to-binance-futures-funding-rates-360033525031",
          "tier": "Tier-1",
          "label": "Binance Funding Rate FAQ",
          "subject_hint": "interval, formula, premium index"
        },
        {
          "url": "https://hyperliquid.gitbook.io/hyperliquid-docs/trading/funding",
          "tier": "Tier-1",
          "label": "Hyperliquid funding-rate documentation",
          "subject_hint": "funding interval, oracle-vs-mid premium"
        },
        {
          "url": "https://www.coingecko.com/en/api/documentation",
          "tier": "Tier-1",
          "label": "CoinGecko Free API",
          "subject_hint": "price history, volume, market cap"
        }
      ]
    },
